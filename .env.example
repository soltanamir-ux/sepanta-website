# ─────────────────────────────────────────────────────────────
# Sepanta LLC — environment variables
# Copy this file to `.env.local` for local development, and set the
# same variables in your Vercel project settings for production.
# ─────────────────────────────────────────────────────────────

# Resend API key — used by the /api/contact route to send contact-form
# submissions by email. Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# The inbox that contact-form submissions are delivered to.
# Example: hello@sepanta.llc
CONTACT_EMAIL=

# The verified "from" address Resend sends on behalf of. Must be an
# address on a domain you have verified in Resend (e.g. no-reply@sepanta.llc).
# If you have not verified a domain yet, Resend's onboarding sandbox address
# `onboarding@resend.dev` works for testing.
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Canonical public site URL (no trailing slash). Used for absolute URLs in
# metadata, sitemap and robots. Defaults to https://sepanta.llc if unset.
NEXT_PUBLIC_SITE_URL=https://sepanta.llc
